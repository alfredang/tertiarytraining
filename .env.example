# PostgreSQL connection string (Coolify will inject for the Database resource)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tertiary_training?schema=public"

# JWT signing secret (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-string"

# One-time token used to bootstrap the first admin via POST /api/admin/seed
SEED_TOKEN="change-me-seed-token"

# Docker integration mode: "mock" (default; safe, no daemon) or "dockerode" (requires /var/run/docker.sock)
DOCKER_HOST_MODE="mock"

# Base URL used when generating container access links in mock mode
PUBLIC_BASE_URL="http://localhost:3000"

# Branding
NEXT_PUBLIC_APP_NAME="Tertiary Training"
