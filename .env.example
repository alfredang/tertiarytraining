# =============================================================================
# Required
# =============================================================================

# PostgreSQL connection string. Coolify injects this from the Database resource
# in production; for local dev point this at your local Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tertiary_training?schema=public"

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET="replace_me_with_a_long_random_string"

# Bootstrap token. Gates POST /api/admin/seed (first admin) and
# POST /api/admin/cleanup-idle (auto-stop cron). Generate with: openssl rand -hex 32
SEED_TOKEN="replace_me_with_seed_token"

# =============================================================================
# Optional — but pinned in dev (see CLAUDE.md)
# =============================================================================

# Public-facing base URL. Used for OAuth callbacks, OTP email links, and the
# mock-docker container URLs. Local dev MUST use port 8016 — the Google and
# GitHub OAuth callback URLs are pinned to http://localhost:8016.
PUBLIC_BASE_URL="http://localhost:8016"

# Branding shown in the admin settings page.
NEXT_PUBLIC_APP_NAME="Tertiary Training"

# Docker integration mode:
#   "mock"      — default, no daemon needed (production currently runs this)
#   "dockerode" — real Docker control via /var/run/docker.sock
DOCKER_HOST_MODE="mock"

# =============================================================================
# Only for DOCKER_HOST_MODE="dockerode"
# =============================================================================

# Public hostname/IP used when generating real container URLs.
# Falls back to PUBLIC_BASE_URL's host, then "localhost".
# PUBLIC_HOST_IP="168.231.119.201"

# Remote Docker engine for routing Ubuntu containers to a separate machine.
# Leave unset to run Ubuntu containers on the local engine.
# REMOTE_DOCKER_HOST="10.0.1.5"
# REMOTE_DOCKER_PORT="2375"

# =============================================================================
# Cleanup job
# =============================================================================

# Auto-stop containers idle for more than this many hours.
# Used by POST /api/admin/cleanup-idle. Default: 2.
# IDLE_AUTOSTOP_HOURS="2"
